# cheapSkate — Environment Configuration
# Copy to .env and fill in values

# Server
PORT=3001

# Admin dashboard token (change in production!)
ADMIN_TOKEN=admin

# Database path (defaults to server/cheapskate.db)
DB_PATH=/app/data/cheapskate.db

# API base URL for the extension (production)
# API_BASE=https://api.cheapskate.gg
