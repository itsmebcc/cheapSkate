{
  "manifest_version": 3,
  "name": "cheapSkate",
  "version": "1.0.0",
  "description": "Cashback & deals — get 50% of the affiliate commission when you shop through cheapSkate",
  "commands": {
    "_execute_action": {
      "description": "Open cheapSkate popup"
    },
    "apply-offer": {
      "description": "Apply current offer at checkout",
      "suggested_key": {
        "default": "Alt+Shift+C",
        "mac": "MacCtrl+Shift+C"
      }
    },
    "open-settings": {
      "description": "Open cheapSkate settings",
      "suggested_key": {
        "default": "Alt+Shift+S",
        "mac": "MacCtrl+Shift+S"
      }
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "cheapskate@cheapskate.gg",
      "strict_min_version": "109.0"
    }
  },
  "permissions": [
    "storage",
    "alarms",
    "tabs"
  ],
  "host_permissions": [
    "http://localhost:3001/*",
    "https://*.cheapskate.gg/*",
    "https://*.amazon.com/*",
    "https://*.ebay.com/*",
    "https://*.walmart.com/*",
    "https://*.target.com/*",
    "https://*.nike.com/*",
    "https://*.adidas.com/*",
    "https://*.bestbuy.com/*",
    "https://*.dell.com/*",
    "https://*.apple.com/*",
    "https://*.samsung.com/*",
    "https://*.hp.com/*",
    "https://*.lenovo.com/*",
    "https://*.homedepot.com/*",
    "https://*.lowes.com/*",
    "https://*.wayfair.com/*",
    "https://*.gap.com/*",
    "https://*.oldnavy.com/*",
    "https://*.macys.com/*",
    "https://*.lululemon.com/*",
    "https://*.booking.com/*",
    "https://*.expedia.com/*",
    "https://*.hotels.com/*",
    "https://*.doordash.com/*",
    "https://*.ubereats.com/*",
    "https://*.hellofresh.com/*",
    "https://*.sephora.com/*",
    "https://*.nordvpn.com/*",
    "https://*.skillshare.com/*",
    "https://*.groupon.com/*",
    "https://*.etsy.com/*",
    "https://*.staples.com/*",
    "https://*.zappos.com/*"
  ],
  "background": {
    "scripts": ["background.js"],
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "exclude_matches": [
        "https://*.google.com/*",
        "https://*.facebook.com/*",
        "https://*.reddit.com/*",
        "https://*.youtube.com/*",
        "https://*.twitter.com/*",
        "https://*.x.com/*",
        "https://*.instagram.com/*",
        "https://*.tiktok.com/*",
        "https://*.linkedin.com/*",
        "https://*.github.com/*",
        "https://*.stackoverflow.com/*",
        "https://*.wikipedia.org/*",
        "https://*.netflix.com/*",
        "https://*.spotify.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "cheapSkate",
    "default_icon": {
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    "onboarding.html",
    "popup.html"
  ]
}
