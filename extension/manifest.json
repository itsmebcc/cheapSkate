{
  "manifest_version": 3,
  "name": "cheapSkate",
  "version": "1.0.0",
  "description": "Cashback & deals — get 50% of the affiliate commission when you shop through cheapSkate",
  "commands": {
    "_execute_action": {
      "description": "Open cheapSkate popup"
    },
    "apply-offer": {
      "description": "Apply current offer at checkout",
      "suggested_key": {
        "default": "Alt+Shift+C",
        "mac": "MacCtrl+Shift+C"
      }
    },
    "open-settings": {
      "description": "Open cheapSkate settings",
      "suggested_key": {
        "default": "Alt+Shift+S",
        "mac": "MacCtrl+Shift+S"
      }
    }
  },
  "permissions": [
    "storage",
    "alarms",
    "tabs"
  ],
  "host_permissions": [
    "http://localhost:3001/*",
    "https://*.cheapskate.gg/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "cheapSkate",
    "default_icon": {
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["onboarding.html", "popup.html"],
      "matches": ["https://*/*", "http://*/*"]
    }
  ]
}
